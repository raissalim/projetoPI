<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Document</title>
<style>
body{
background-color: #fde55f;
}
</style>
</head>
<body>

<h1>Calculadora sobre média de Abelhas Europeias(<i>Apis mellifera</i>) <br>
em caixas modelo Langstroth no Brasil 🐝🗃️:</h1>
<br>
<h2><span>Informe a quantidade de caixa(s) de abelha(s): </span><input type="number" id="ipt_caixa"><span>.</span></h2>
<br>
<h2><span>Informe o número de quadro(s) por caixa: </span><input type="number" id="ipt_num_quadro"><span>.</span></h2>

<br>

<button onclick="calcular()">Calcular abelha(s)</button>

<div id="div_alert"></div>

</body>
</html>
<script>

function calcular(){

let caixa = Number (ipt_caixa.value);
let quadro = Number (ipt_num_quadro.value);

let frq_ref = 180; // Valor imaginário pois ainda não temos os dados do sensor.
// frq_ref = frequência de referência.

// 180 = valor para caixa fraca. (72%).
// 250= valor para caixa normal. (100%).
// 320= valor para caixa forte. (128%).
// 240 = teste para mostrar até onde vai a estimativa da população. (96%).
// 210 = teste para mostrar até onde vai a estimativa da população. (84%).
// 220 = teste para mostrar até onde vai a estimativa da população. (88%).
// 200 = teste para mostrar até onde vai a estimativa da população. (80%).

div_alert.innerHTML = "";

let pop_max = ((quadro * 9000) * caixa); // 9000 porque é a quantidade máxima de Abelhas Europeias que um quadro pode atingir.
// pop_max = população máxima.

let pop_max_total = (pop_max / caixa); // Para encontrar a quantidade máxima que aquela caixa deve atingir em média.

let pop_min = ((quadro * 7000) * caixa); // 7000 porque é a quantidade mínima de Abelhas Europeias que um quadro pode atingir.

let pop_min_total = (pop_min / caixa); // Para encontrar a quantidade mínima que aquela caixa deve atingir em média.

let ind_ocp_virgu = (frq_ref / 250); // 250 porque é a média de frequência que as Abelhas Europeias produzem.
// ind_ocp_virgu = índice de ocupação (inteiro, número com vírgula).

let ind_ocp_porc = ((frq_ref / 250) * 100); // ind_ocp_porc = índice de ocupação (porcentagem, número inteiro).

let pop_media = (((((pop_max + pop_min) / 2) * ind_ocp_virgu) / caixa)); // achar o valor médio de abelhas dentro de uma caixa.
// pop_media = população média.

let abelhasQueMorreriam = pop_media * 0.05; // Usamos 0.05 (5%) como a taxa de mortalidade natural diária

let lucroPorAbelha = 0.015; //Cada abelha produz cerca de 5g de mel (R$ 0,015)

let prejuizo2 = abelhasQueMorreriam * lucroPorAbelha;

let totalMortesApiario = abelhasQueMorreriam;



if (caixa >= 1){

div_alert.innerHTML += `
<br><h3>A população máxima que pode ter em cada caixa Langstroth é de ${pop_max_total} e o total de população que tem dentro das suas caixas é de <b>${pop_max}</b> .</br></h3>
<h3>Já a quantidade mínima é de cada caixa é de ${pop_min_total} e o total de caixas é ${pop_min} abelhas.</h3>
<h3>E o índice de ocupação é de: ${ind_ocp_porc}%.</h3>
<h3>A quantidade de abelhas que morrem por dia sem o nosso sensor : ${(totalMortesApiario)}.</h3>
<h3>A quantidade de prejuizo que você tem sem o nosso sensor por dia é :R$ ${(prejuizo2.toFixed(0))}.</h3>
<h3><br><span style="color: red;">Legenda: O lucro diário do mel por abelha é de R$ 0,015 (De acordo com o site da CPT que calculam lucros de colmeias).</span><br></h3>
<h3><span style="color: red;">Legenda: O total de mortes de abelha por colmeia é de 5% (De acordo com o site do reporter Brasil).</span</h3>
`

};


}

</script>
